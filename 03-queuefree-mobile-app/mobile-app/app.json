{
  "expo": {
    "name": "QueueFree",
    "slug": "queuefree",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "owner": "Ricch00",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a56db"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gh.edu.queuefree"
    },
    "android": {
      "package": "gh.edu.queuefree",
      "adaptiveIcon": {
        "backgroundColor": "#1a56db"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false
          }
        }
      ]
    ]
  }
}
